# ── LLM Provider ──────────────────────────────────────────────
# Pick one provider; comment out the others

# Option A: Anthropic Claude (direct, no markup)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=your_anthropic_key_here

# Option B: OpenAI (direct)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=your_openai_key_here

# Option C: Ollama (self-hosted, free — start with: docker compose --profile local-llm up)
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama

# Option D: Mock (for UI development — no API calls, random canned responses)
# LLM_PROVIDER=mock

# Embedding
OPENAI_API_KEY=

# ── Infrastructure ─────────────────────────────────────────────
JUDGE0_URL=http://judge0:2358
REDIS_URL=redis://redis:6379

# ── Voice─────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
